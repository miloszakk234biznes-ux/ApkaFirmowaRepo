# ──────────────────────────────────────────────────────────────────────────
# Plik: .env.example
# Cel: Wzór zmiennych środowiskowych. Skopiuj do `.env` i uzupełnij wartości.
#      NIE commituj pliku `.env` (jest w .gitignore).
# ──────────────────────────────────────────────────────────────────────────

# ── Baza danych (PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql://UŻYTKOWNIK:HASŁO@HOST:PORT/NAZWA_BAZY?schema=public
# Lokalnie (docker-compose) host to "db". Na Railway/Supabase użyj ich connection stringa.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apkafirmowa?schema=public"

# ── NextAuth.js ─────────────────────────────────────────────────────────────
# Pełny URL aplikacji (bez końcowego ukośnika). Prod: https://twojadomena.pl
NEXTAUTH_URL="http://localhost:3000"
# Sekret do podpisywania tokenów JWT/sesji. Wygeneruj: `openssl rand -base64 32`
NEXTAUTH_SECRET="zmien-mnie-na-losowy-ciag-min-32-znaki"

# ── SMTP (nodemailer) — reset hasła i powiadomienia e-mail ─────────────────
# Bez konfiguracji SMTP aplikacja zadziała, ale e-maile będą logowane do konsoli (dev).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
# Adres nadawcy widoczny w wiadomościach.
SMTP_FROM="ApkaFirmowa <no-reply@apkafirmowa.app>"

# ── Zmienne zarezerwowane na kolejne etapy (na razie opcjonalne) ───────────
# Etap 3 — Google Calendar OAuth (instrukcja: docs/GOOGLE_CALENDAR.md)
# Z Google Cloud Console → Credentials → OAuth client ID (typ: Web application).
# Authorized redirect URI musi być: {NEXTAUTH_URL}/api/google-calendar/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# Strefa czasowa eventów tworzonych w Google (domyślnie Europe/Warsaw).
# GOOGLE_CALENDAR_TIMEZONE="Europe/Warsaw"
# Token weryfikujący webhook push (dowolny losowy ciąg; opcjonalny, zalecany).
# GOOGLE_WEBHOOK_TOKEN=""
# Klucz szyfrowania danych wrażliwych (refresh token Google) — AES-256-GCM.
# Wygeneruj: openssl rand -base64 32. Brak → fallback do NEXTAUTH_SECRET.
# ENCRYPTION_KEY=""
# Etap 6 — Twilio SMS:
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""
# Etap 2/4 — Uploadthing:
# UPLOADTHING_SECRET=""
# UPLOADTHING_APP_ID=""

# ── Etap 2 — Załączniki (upload plików) ───────────────────────────────────
# Katalog zapisu uploadów (zdjęcia/dokumenty zleceń). Domyślnie public/uploads.
# Produkcyjnie na VPS/Docker zamontuj wolumen na ten katalog; na Vercel użyj S3.
# UPLOAD_DIR="/app/public/uploads"
